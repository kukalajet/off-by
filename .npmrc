# Expo / React Native tooling (Metro, babel-preset-expo, the expo-updates Xcode
# build phase) resolves many packages by bare name via plain Node resolution.
# pnpm's default isolated linker only symlinks DIRECT deps into each package's
# node_modules, so transitive presets like `babel-preset-expo` are unresolvable
# and EAS builds fail constructing the Metro transformer. Hoisted layout fixes it.
node-linker=hoisted
